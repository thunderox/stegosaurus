@prefix lv2: <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ui: <http://lv2plug.in/ns/extensions/ui#> .
@prefix pset: <http://lv2plug.in/ns/ext/presets#> .

<http://nickbailey.co.nr/plugins/stegosaurus>
	a lv2:Plugin ;
	lv2:binary <stegosaurus@LIB_EXT@> ;
	rdfs:seeAlso <stegosaurus.ttl> .

<http://nickbailey.co.nr/plugins/stegosaurus#ui>
	a <@UI_TYPE@> ;
	ui:binary <stegosaurus_ui@LIB_EXT@> ;
	rdfs:seeAlso <stegosaurus.ttl> .
	
<stegosaurus-presets.lv2/electro.ttl>
	a pset:Preset ;
	rdfs:seeAlso <stegosaurus-presets.lv2/electro.ttl> ;
	lv2:appliesTo <http://nickbailey.co.nr/plugins/stegosaurus> .
		
